# ─── 로컬 개발 (npm run dev) ───
# 이 파일을 복사:  cp .env.example .env  후 .env 에 실제 키 입력
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (선택) Vite 관례 이름도 동일하게 동작합니다.
# VITE_GEMINI_API_KEY=

# ─── GitHub → Firebase 배포 (npm run build 없이 Actions만 쓸 때) ───
# 저장소 Settings → Secrets and variables → Actions → New repository secret
#   이름: GEMINI_API_KEY
#   값:  위와 동일한 API 키
# 워크플로가 빌드할 때 위 시크릿을 읽어 번들에 넣습니다. (.env는 Git에 올리지 마세요)
